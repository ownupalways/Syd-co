{
	"compilerOptions": {
		"types": ["vite/client"],
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"ignoreDeprecations": "5.0",

		"paths": {
			"@/*": ["./src/*"],
			"@components/*": ["./src/components/*"],
			"@pages/*": ["./src/pages/*"],
			"@store/*": ["./src/store/*"],
			"@api/*": ["./src/api/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@typings/*": ["./src/types/*"],
			"@utils/*": ["./src/utils/*"]
		}
	},
	"include": ["src"]
}
