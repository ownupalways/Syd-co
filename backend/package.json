{
  "name": "sydney-shopping-backend",
  "version": "1.0.0",
  "description": "Sydney Shopping E-Commerce Backend API",
  "main": "dist/server.js",
  "type": "commonjs",

  "_moduleAliases": {
  "@": "src",
  "@utils": "src/utils",
  "@config": "src/config",
  "@controllers": "src/controllers",
  "@models": "src/models",
  "@routes": "src/routes",
  "@middleware": "src/middleware"
},

  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prod": "npm run build && npm start",

    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",

    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",

    "seed:admin": "ts-node -r tsconfig-paths/register src/utils/seedAdmin.ts"
  },

  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "typescript",
    "mongodb"
  ],

  "author": "Godwin J. Oluwadipe",
  "license": "MIT",

  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.8.3",
    "stripe": "^14.0.0",
    "winston": "^3.11.0",
    "ws": "^8.20.0"
  },

  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",

    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",

    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",

    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  },

  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
